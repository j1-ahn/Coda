# -------------------------------------------------------------------------
# Coda Studio — Frontend environment
# Copy to `.env.local` and tweak per-machine. `.env.local` is gitignored.
# -------------------------------------------------------------------------

# Backend API origin. Used by:
#   - next.config.js `/api/*` rewrite target
#   - src/lib/api.ts (apiFetch base URL + health probe)
#   - Direct uploads that bypass the Next.js proxy (big audio files)
#
# Override if the backend runs on a non-default port (e.g. when 8000 is
# taken by another process — start uvicorn with `--port 8001` and set:
#   NEXT_PUBLIC_BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
